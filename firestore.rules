rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Status/config da loja é info pública — qualquer dispositivo lê sem precisar de auth
    // Só admin (login com e-mail) pode escrever
    match /loja/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    // Pedidos: qualquer autenticado cria, só admin lê/deleta
    match /pedidos/{document} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && request.auth.token.email != null;
    }
  }
}
